# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# python
forecast-service/venv/
forecast-service/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# local data / scripts output
data/

# secrets / credentials (never commit)
agentic_cardseller_passwds
*.key
.haiku

# notebooks: heavy training data, artifacts, model binaries (keep out of git)
notebooks/datasets/
notebooks/artifacts/
notebooks/cards/
**/.ipynb_checkpoints/
*.pt
*.pkl

# python envs / caches
**/venv/
.venv/

# grading_server runtime collateral
grading_server/feedback/
grading_server/__pycache__/

# backend runtime feedback
backend/feedback/

# Beta grading deploy: bundle ONLY the YOLO OBB weights (small) for Railway
!backend/models/yolo_obb_best.pt
