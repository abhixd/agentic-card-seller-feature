# =============================================================================
# agentic-card-seller-os — environment template
# Copy to .env.local for local dev, and set the same values in
# Vercel → Settings → Environment Variables (Production + Preview) for deploy.
# Each var is labeled with what it unlocks. Tiers = do Tier 1 first.
# =============================================================================

# ── Already configured (required to even boot) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=          # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Supabase anon/public key (safe to expose)
GRADING_API_URL=https://card-grader-api-production.up.railway.app   # CV grader (Railway)
GRADING_SERVICE_URL=https://card-grader-api-production.up.railway.app

# ── TIER 1 — unlocks the most; do these first ────────────────────────────────
EBAY_APP_ID=                       # eBay sold comps → consensus/valuation/risk/liquidity/gem-rate (BIGGEST unlock)
EBAY_FINDING_API_BASE_URL=         # eBay Finding API base url
JUSTTCG_API_KEY=                   # TCGplayer price history → charts, % moves, top-100 charts, forecast
JUSTTCG_CRON_BATCH=25              # cards refreshed per cron run. 25 = free-tier-safe (1k calls/mo); raise to 60+ on a paid JustTCG tier
SUPABASE_SERVICE_ROLE_KEY=         # SECRET. catalog search/sync, caching, all cron writes
CRON_SECRET=                       # any long random string — authorizes the scheduled cron jobs
POKEMON_TCG_API_KEY=               # catalog sync + current TCGplayer prices

# ── TIER 2 — important features ──────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # AI market intelligence, news, chat copilot
FORECAST_SERVICE_URL=              # Prophet forecast microservice (local fallback works without it)
FORECAST_API_SECRET=               # auth for the forecast service
PSA_BEARER_TOKEN=                  # PSA cert lookup + population reports
PRICECHARTING_API_TOKEN=           # PriceCharting history, sealed products, set CAGR metrics

# ── TIER 3 — optional / later ────────────────────────────────────────────────
EBAY_CLIENT_ID=                    # eBay Sell API (listing/selling) — OAuth
EBAY_CLIENT_SECRET=
EBAY_RUNAME=
EBAY_SANDBOX=true                  # use eBay sandbox while testing
AI_PROVIDER=anthropic              # chat provider: anthropic | openai | ollama
OPENAI_API_KEY=                    # only if AI_PROVIDER=openai
OLLAMA_BASE_URL=                   # only if AI_PROVIDER=ollama
ADMIN_EMAILS=                      # comma-separated admin emails (admin page gate)

# Notes:
# - Crons run ONLY on the deployed Vercel app, never locally.
# - Vercel Hobby allows 2 daily crons; 6 (every 6h) needs Vercel Pro.
# - After keys are set, run /api/cron/sync-cards + /api/cron/sync-price-history
#   once (or wait for the schedule) to populate prices and the top-100 charts.
