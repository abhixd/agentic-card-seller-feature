  "required": [
    "centering",
    "corners",
    "edges",
    "surface"
  ],
  "title": "GradeResponse",
  "type": "object",
  "$id": "https://acs/grading-contract/grade-response.schema.json",
  "x-contract-version": "1.0.0"
