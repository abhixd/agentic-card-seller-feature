{
  "$defs": {
    "Centering": {
      "additionalProperties": true,
      "properties": {
        "score": {
          "title": "Score",
          "type": "number"
        },
        "left_right": {
          "examples": [
            "49/51"
          ],
          "title": "Left Right",
          "type": "string"
        },
        "top_bottom": {
          "examples": [
            "60/40"
          ],
          "title": "Top Bottom",
          "type": "string"
        },
        "reliable": {
          "title": "Reliable",
          "type": "boolean"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "content_region": {
          "anyOf": [
            {
              "$ref": "#/$defs/ContentRegion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        }
      },
      "required": [
        "score",
        "left_right",
        "top_bottom",
        "reliable"
      ],
      "title": "Centering",
      "type": "object"
    },
    "ContentRegion": {
      "description": "Inner-content bounds as fractions of the warped card (0..1).",
      "properties": {
        "x1": {
          "title": "X1",
          "type": "number"
        },
        "y1": {
          "title": "Y1",
          "type": "number"
        },
        "x2": {
          "title": "X2",
          "type": "number"
        },
        "y2": {
          "title": "Y2",
          "type": "number"
        }
      },
      "required": [
        "x1",
        "y1",
        "x2",
        "y2"
      ],
      "title": "ContentRegion",
      "type": "object"
    },
    "Issues": {
