          "type": "array"
        },
        "edges": {
          "items": {
            "type": "string"
          },
          "title": "Edges",
          "type": "array"
        },
        "surface": {
          "items": {
            "type": "string"
          },
          "title": "Surface",
          "type": "array"
        },
        "centering": {
          "items": {
            "type": "string"
          },
          "title": "Centering",
          "type": "array"
        }
      },
      "title": "Issues",
      "type": "object"
    },
    "Pillar": {
