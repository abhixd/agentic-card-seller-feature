{
  "$defs": {
    "Centering": {
      "additionalProperties": true,
      "properties": {
        "score": {
          "title": "Score",
          "type": "number"
        },
        "left_right": {
          "examples": [
            "49/51"
          ],
          "title": "Left Right",
          "type": "string"
        },
        "top_bottom": {
          "examples": [
            "60/40"
          ],
          "title": "Top Bottom",
          "type": "string"
        },
        "reliable": {
          "title": "Reliable",
          "type": "boolean"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "content_region": {
          "anyOf": [
            {
              "$ref": "#/$defs/ContentRegion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "stability": {
          "anyOf": [
            {
              "$ref": "#/$defs/Stability"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "registration": {
          "anyOf": [
            {
              "$ref": "#/$defs/Registration"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "score",
        "left_right",
        "top_bottom",
        "reliable"
      ],
      "title": "Centering",
      "type": "object"
    },
    "ContentRegion": {
      "description": "Inner-content bounds as fractions of the warped card (0..1).",
      "properties": {
        "x1": {
          "title": "X1",
          "type": "number"
        },
        "y1": {
          "title": "Y1",
          "type": "number"
        },
        "x2": {
          "title": "X2",
          "type": "number"
        },
        "y2": {
          "title": "Y2",
          "type": "number"
        }
      },
      "required": [
        "x1",
        "y1",
        "x2",
        "y2"
      ],
      "title": "ContentRegion",
      "type": "object"
    },
    "Defect": {
      "additionalProperties": true,
      "description": "One detected defect: a bounding box [x, y, w, h] in FRACTIONS of the warped card (0..1, origin\ntop-left) plus its classification. Producers: the Sonnet/Opus condition detector (all pillars) and the\nlocal RF-DETR scratch detector (surface). `extra=allow` so producer-specific keys pass through.",
      "properties": {
        "area": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Area"
        },
        "type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Type"
        },
        "category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Category"
        },
        "box": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Box"
        },
        "conf": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Conf"
        }
      },
      "title": "Defect",
      "type": "object"
    },
    "DefectBoxes": {
      "description": "Per-pillar detected defects \u2192 outline rectangles drawn over the warped card.",
      "properties": {
        "edges": {
          "items": {
            "$ref": "#/$defs/Defect"
          },
          "title": "Edges",
          "type": "array"
        },
        "corners": {
          "items": {
            "$ref": "#/$defs/Defect"
          },
          "title": "Corners",
          "type": "array"
        },
        "surface": {
          "items": {
            "$ref": "#/$defs/Defect"
          },
          "title": "Surface",
          "type": "array"
        }
      },
      "title": "DefectBoxes",
      "type": "object"
    },
    "Issues": {
      "properties": {
        "corners": {
          "items": {
            "type": "string"
          },
          "title": "Corners",
          "type": "array"
        },
        "edges": {
          "items": {
            "type": "string"
          },
          "title": "Edges",
          "type": "array"
        },
        "surface": {
          "items": {
            "type": "string"
          },
          "title": "Surface",
          "type": "array"
        },
        "centering": {
          "items": {
            "type": "string"
          },
          "title": "Centering",
          "type": "array"
        }
      },
      "title": "Issues",
      "type": "object"
    },
    "Pillar": {
      "description": "Corners / edges / surface.",
      "properties": {
        "score": {
          "title": "Score",
          "type": "number"
        },
        "worst_severity": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worst Severity"
        }
      },
      "required": [
        "score"
      ],
      "title": "Pillar",
      "type": "object"
    },
    "Registration": {
      "description": "Print-registration read (PRINT_REG=1): the identified card's official render is SIFT-registered\nagainst the die-cut warp; when accepted, left_right/top_bottom/content_region come from the registered\nprint position (sub-pixel; solves full-arts with no detectable inner frame). accepted=False = the\nselector read was kept; this block then only explains why (reason).",
      "properties": {
        "accepted": {
          "title": "Accepted",
          "type": "boolean"
        },
        "inliers": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inliers"
        },
        "matches": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matches"
        },
        "resid_px": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resid Px"
        },
        "scale": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scale"
        },
        "ref_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ref Id"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "gate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gate"
        },
        "tried": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tried"
        },
        "outer_corrected": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outer Corrected"
        },
        "cut_edge_support": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cut Edge Support"
        },
        "outer_tightened": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outer Tightened"
        },
        "frame_insets": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Frame Insets"
        }
      },
      "required": [
        "accepted"
      ],
      "title": "Registration",
      "type": "object"
    },
    "Stability": {
      "description": "Test\u2013retest stability probe (?stability=1): the card is graded a second time on a label-preserving\nperturbation (98% resize + JPEG re-encode) and delta_pts is the largest centering margin-share move in\npoints. Stable reads sit at ~1pt; fragile reads (faint sleeve edges) flip by 3\u201329pt while LOOKING\nconfident. `confidence` is the 0..1 ramp of delta_pts, already MIN-combined into centering.confidence.",
      "properties": {
        "delta_pts": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delta Pts"
        },
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "probe_left_right": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Probe Left Right"
        },
        "probe_top_bottom": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Probe Top Bottom"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "title": "Stability",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "properties": {
    "overall_score": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Overall Score"
    },
    "psa_equivalent": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Psa Equivalent"
    },
    "summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Summary"
    },
    "centering": {
      "$ref": "#/$defs/Centering"
    },
    "corners": {
      "$ref": "#/$defs/Pillar"
    },
    "edges": {
      "$ref": "#/$defs/Pillar"
    },
    "surface": {
      "$ref": "#/$defs/Pillar"
    },
    "issues": {
      "anyOf": [
        {
          "$ref": "#/$defs/Issues"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "confidence": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence"
    },
    "pillar_visuals": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pillar Visuals"
    },
    "pillar_zooms": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pillar Zooms"
    },
    "defect_boxes": {
      "anyOf": [
        {
          "$ref": "#/$defs/DefectBoxes"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "economics": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Economics"
    },
    "decision": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Decision"
    }
  },
  "required": [
    "centering",
    "corners",
    "edges",
    "surface"
  ],
  "title": "GradeResponse",
  "type": "object",
  "$id": "https://acs/grading-contract/grade-response.schema.json",
  "x-contract-version": "1.9.0"
}