{
  "name": "agentic-card-seller-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "description": "Monorepo: web app (apps/web), Chrome extension (apps/extension), Python microservices (services/*).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "web": "npm run dev --workspace @acs/web"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
