{
  "manifest_version": 3,
  "name": "Card Seller OS — Grader",
  "version": "1.0.0",
  "description": "Instant PSA grade estimates + buy/skip decisions for eBay card listings.",

  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "contextMenus"
  ],

  "host_permissions": [
    "https://www.ebay.com/*",
    "https://ebay.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://127.0.0.1:8000/*"
  ],

  "action": {
    "default_title": "Card Seller OS",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.ebay.com/itm/*", "https://ebay.com/itm/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
