# Dockerfile.grading — Python grading API for Railway
# Build context: REPO ROOT (Railway service Root Directory must be EMPTY/blank).
# COPY paths are repo-relative (services/grading-api/...). This mirrors the proven
# pre-monorepo setup (root context + Dockerfile.grading), just from the new location.

FROM python:3.11-slim

WORKDIR /app

# System deps required by OpenCV headless
RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 libsm6 libxext6 libxrender1 libgomp1 libgl1 \
    && rm -rf /var/lib/apt/lists/*

# Install CPU-only PyTorch first — avoids pulling the 2 GB CUDA wheel.
# Unpinned so pip resolves a compatible torch/torchvision pair from the CPU index
# (the old 2.3.0+cpu pin was removed from the index). Pin later for reproducibility.
RUN pip install --no-cache-dir \
    torch torchvision \
    --index-url https://download.pytorch.org/whl/cpu

# Copy and install remaining deps (skip torch/torchvision — already installed)
COPY services/grading-api/requirements.txt /tmp/requirements.txt
RUN grep -vE "^torch|^torchvision" /tmp/requirements.txt \
    | sed 's/opencv-python/opencv-python-headless/' \
    | pip install --no-cache-dir -r /dev/stdin

# Copy backend source
# Backend source: product API (main/inference/schemas/comps) + the grading
# pipeline (grader/aggregator/grade_comps/grade_model) used by /grade.
COPY services/grading-api/main.py services/grading-api/inference.py services/grading-api/schemas.py services/grading-api/comps.py \
     services/grading-api/grader.py services/grading-api/aggregator.py services/grading-api/grade_comps.py \
     services/grading-api/identify.py \
     services/grading-api/card_segmenter.py \
     services/grading-api/cv_grader.py services/grading-api/nonvlm_cv.py services/grading-api/inner_frame.py \
     services/grading-api/per_side_selector.py services/grading-api/inner_frame_var.py services/grading-api/inner_frame_dp.py \
     services/grading-api/trainer.py services/grading-api/model_store.py \
     services/grading-api/config.py services/grading-api/centering_config.yaml \
     services/grading-api/grade_model.json services/grading-api/feedback_to_yolo.py ./

# per-side selector model + bundled base training set (for /admin/train server-side retrain)
COPY services/grading-api/perside_lr.joblib services/grading-api/perside_base_dataset.json ./

# Grading-only deploy. /grade defaults to the classical-CV backend (cv_grader +
# cv_xgb_raw.pkl); the YOLO weights stay for detection fallback and the Claude VLM
# path stays available behind GRADER_BACKEND=vlm. The MLP /analyze-listing path is
# NOT part of the Beta surface, so its artefacts are intentionally not bundled.
COPY services/grading-api/models/yolo_obb_best.pt ./models/yolo_obb_best.pt
COPY services/grading-api/models/cv_xgb_raw.pkl  ./models/cv_xgb_raw.pkl

# Default env — Railway overrides PORT at runtime
ENV YOLO_WEIGHTS=/app/models/yolo_obb_best.pt
# MODEL_PATH points at an absent file on purpose: the MLP /analyze-listing path
# stays disabled (lifespan tolerates it); /grade is unaffected.
ENV MODEL_PATH=/app/models/disabled-mlp.pt
ENV PYTHONUNBUFFERED=1
ENV PORT=8000

EXPOSE 8000

# Use shell form so Railway's $PORT is expanded at runtime
CMD uvicorn main:app --host 0.0.0.0 --port ${PORT}
