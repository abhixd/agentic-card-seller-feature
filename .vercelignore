# Exclude top-level dirs not needed for the Next.js build.
# NOTE: patterns are ROOT-ANCHORED (leading slash). An unanchored "supabase/"
# also matches src/lib/supabase/ and would break the build — keep the slash.
/notebooks/
/backend/
/grading_server/
/extension/
/data/
/docs/
/forecast-service/
/optimize-service/
/supabase/
/scripts/
/coverage/
